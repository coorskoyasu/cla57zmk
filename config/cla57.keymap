            timeout-ms = <30>;
        };

        nicola_r_c {
            bindings = <&macroZU>;
            key-positions = <65 45>;
            layers = <NICOLA>;
            timeout-ms = <30>;
        };

        nicola_r_v {
            bindings = <&macroBU>;
            key-positions = <65 46>;
            layers = <NICOLA>;
            timeout-ms = <30>;
        };

        nicola_r_b {
            bindings = <&macroBE>;
            key-positions = <65 47>;
            layers = <NICOLA>;
            timeout-ms = <30>;
        };

        nicola_r_n {
            bindings = <&macroPU>;
            key-positions = <65 48>;
            layers = <NICOLA>;
            timeout-ms = <30>;
        };

        nicola_r_m {
            bindings = <&macroZO>;
            key-positions = <65 49>;
            layers = <NICOLA>;
            timeout-ms = <30>;
        };

        nicola_r_comma {
            bindings = <&macroPE>;
            key-positions = <65 50>;
            layers = <NICOLA>;
            timeout-ms = <30>;
        };

        nicola_r_dot {
            bindings = <&macroBO>;
            key-positions = <65 51>;
            layers = <NICOLA>;
            timeout-ms = <30>;
        };
    };

    /* ============================================================
     *  Keymap
     * ============================================================ */
    keymap {
        compatible = "zmk,keymap";

        /* --------------------------------------------------------
         * Layer 0: DEFAULT (QWERTY) - LED: Blue
         * -------------------------------------------------------- */
        default_layer {
            bindings = <
&lt FUNC ESC      &kp N1    &kp N2     &kp N3     &kp N4             &kp N5     &kp LEFT_GUI           &bt BT_NXT     &kp N6         &kp N7                &kp N8      &kp N9      &kp N0      &kp MINUS
&kp TAB           &kp Q     &kp W      &kp E      &kp R              &kp T      &kp LC(SPACE)          &kp RC(SPACE)  &kp Y          &kp U                 &kp I       &kp O       &kp P       &kp LEFT_BRACE
&kp LEFT_CONTROL  &kp A     &kp S      &kp D      &kp F              &kp G      &to_default            &to_nicola     &kp H          &kp J                 &kp K       &kp L       &kp SEMI    &kp BACKSPACE
&kp LEFT_SHIFT    &kp Z     &kp X      &kp C      &kp V              &kp B                                            &kp N          &kp M                 &kp COMMA   &kp DOT     &kp SLASH   &kp RIGHT_SHIFT
&kp LEFT          &kp DOWN  &kp UP     &kp RIGHT                                                                                     &kp LEFT              &kp DOWN    &kp UP      &kp RIGHT
                                                   &kp INTERNATIONAL_5  &to_default                                    &to_nicola     &kp INTERNATIONAL_4
                                                                        &kp SPACE      &mo FUNC                        &kp RC(SPACE)  &mo FUNC
                                                                        &kp DEL        &kp LEFT_ALT                    &to_nicola     &kp RET
            >;
        };

        /* --------------------------------------------------------
         * Layer 1: NICOLA (thumb shift Japanese input) - LED: Red
         *
         * Unshifted:
         *   。 か た こ さ    ら ち く つ 、
         *   う し て け せ    は と き い ん
         *   。 ひ す ふ へ    め そ ね ほ ・
         *
         * + Left thumb (無変換):
         *   ぁ え り ゃ れ    よ に る ま ぇ
         *   を あ な ゅ も    み お の ょ っ
         *   ぅ ー ろ や ぃ    ぬ ゆ む わ ぉ
         *
         * + Right thumb (変換):
         *      が だ ご ざ    ぱ ぢ ぐ づ ぴ
         *   ゔ じ で げ ぜ    ば ど ぎ ぽ
         *      び ず ぶ べ    ぷ ぞ ぺ ぼ
         * -------------------------------------------------------- */
        nicola_layer {
            bindings = <
&kp ESC           &kp N1      &kp N2     &kp N3     &kp N4             &kp N5     &kp LEFT_GUI           &bt BT_NXT     &kp N6         &kp N7                &kp N8      &kp N9      &kp N0      &kp MINUS
&kp TAB           &kp PERIOD  &macroKA   &macroTA   &macroKO           &macroSA   &kp LC(SPACE)          &kp RC(SPACE)  &macroRA       &macroTI              &macroKU    &macroTU    &kp COMMA   &kp LEFT_BRACE
&kp LEFT_CONTROL  &kp U       &macroSI   &macroTE   &macroKE           &macroSE   &to_default            &to_nicola     &macroHA       &macroTO              &macroKI    &kp I       &macroNN    &kp BACKSPACE
&kp LEFT_SHIFT    &kp PERIOD  &macroHI   &macroSU   &macroHU           &macroHE                                         &macroME       &macroSO              &macroNE    &macroHO    &kp SLASH   &kp RIGHT_SHIFT
&kp LEFT          &kp DOWN    &kp UP     &kp RIGHT                                                                                     &kp LEFT              &kp DOWN    &kp UP      &kp RIGHT
                                                     &kp INTERNATIONAL_5  &to_default                                    &to_nicola     &kp INTERNATIONAL_4
                                                                          &kp SPACE      &mo FUNC                        &kp RC(SPACE)  &mo FUNC
                                                                          &kp DEL        &kp LEFT_ALT                    &to_default    &kp RET
            >;
        };

        /* --------------------------------------------------------
         * Layer 2: FUNC (Function / Media / BT) - LED: Green
         * -------------------------------------------------------- */
        func_layer {
            bindings = <
&bootloader  &kp F1          &kp F2          &kp F3          &kp F4          &kp F5         &trans                &trans          &kp F6     &kp F7     &kp F8      &kp F9   &kp F10            &bootloader
&trans       &kp F11         &kp F12         &trans          &trans          &trans         &trans                &trans          &trans     &trans     &trans      &trans   &kp C_PLAY_PAUSE   &kp C_VOL_UP
&trans       &bt BT_SEL 0    &bt BT_SEL 1    &bt BT_SEL 2    &bt BT_SEL 3    &bt BT_SEL 4   &to_default           &to_nicola      &trans     &kp UP     &trans      &trans   &kp C_NEXT         &kp C_VOL_DN
&trans       &bt BT_CLR      &bt BT_CLR_ALL  &bt BT_NXT      &bt BT_PRV      &trans                                               &kp LEFT   &kp DOWN   &kp RIGHT   &trans   &kp C_PREVIOUS     &kp C_MUTE
&trans       &trans          &trans          &trans                                                                                            &trans     &trans      &trans   &trans
                                                              &trans          &trans                                               &trans     &trans
                                                                              &trans          &trans                               &trans     &trans
                                                                              &trans          &kp LEFT_GUI                         &trans     &trans
            >;
        };
    };
};
