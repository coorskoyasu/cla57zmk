/*
 * CLA57 - Japanese NICOLA Thumb Shift Split Keyboard
 * CPU: nRF52840 (nice_nano_v2)
 *
 * Layer 0 (DEFAULT): QWERTY base layer          - LED: Blue
 * Layer 1 (NICOLA):  NICOLA thumb shift layout   - LED: Red
 * Layer 2 (FUNC):    Function / media / BT       - LED: Green
 *
 * Left thumb shift  = INTERNATIONAL_5 (Muhenkan / 無変換) at position 62
 * Right thumb shift = INTERNATIONAL_4 (Henkan / 変換)     at position 65
 * Combo timeout: 30ms
 *
 * Key position map (74 keys total):
 *   Row 0: pos  0- 13 (14 keys)
 *   Row 1: pos 14- 27 (14 keys)
 *   Row 2: pos 28- 41 (14 keys)
 *   Row 3: pos 42- 53 (12 keys)
 *   Row 4: pos 54- 61 ( 8 keys)
 *   Thumb1: pos 62-65 ( 4 keys) ← thumb shift keys here
 *   Thumb2: pos 66-69 ( 4 keys)
 *   Thumb3: pos 70-73 ( 4 keys)
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
/* #include <dt-bindings/zmk/rgb.h> */

#define DEFAULT 0
#define NICOLA  1
#define FUNC    2

/ {

    /* ============================================================
     *  Macros
     * ============================================================ */
    macros {

        /* --- Layer switch with LED color --- */

        to_default: to_default {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&to DEFAULT>;
            label = "TO_DEFAULT";
        };

        to_nicola: to_nicola {
