    /* ============================================================
     *  Combos - NICOLA thumb shift (Layer 1 only, 30ms timeout)
     *
     *  Left thumb  = position 62 (INTERNATIONAL_5 / 無変換)
     *  Right thumb = position 65 (INTERNATIONAL_4 / 変換)
     * ============================================================ */
    combos {
        compatible = "zmk,combos";

        /* ---- Left thumb shift (pos 62) + Row 1 ---- */

        nicola_l_q {
            bindings = <&macroLa>;
            key-positions = <62 15>;
            layers = <NICOLA>;
            timeout-ms = <30>;
